ENVIRONMENT=production
APP_NAME=Job Tracker API
HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql+psycopg2://<db_user>:<db_password>@<db_host>:5432/<db_name>
DB_HOST=<db_host>
DB_PORT=5432
DB_NAME=<db_name>
DB_USER=<db_user>
DB_PASSWORD=<db_password>

SECRET_KEY=<minimum-32-char-random-secret>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_CODE_EXPIRE_MINUTES=15
LOGIN_OTP_EXPIRE_MINUTES=10

ALLOWED_ORIGINS=https://your-frontend-domain.com
ALLOW_CREDENTIALS=True
ALLOW_METHODS=*
ALLOW_HEADERS=*


SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_PASSWORD=npni gvgd xhkw aeej
SMTP_FROM_EMAIL=<no-reply@jobtracker-admin.com>
SMTP_FROM_NAME=Job Tracker
SMTP_USE_TLS=True
SMTP_USE_SSL=False

FRONTEND_URL=http://localhost:5173


AWS_ACCESS_KEY_ID=<aws-access-key>
AWS_SECRET_ACCESS_KEY=<aws-secret-key>
AWS_REGION=<aws-region>
S3_BUCKET_NAME=<s3-bucket>

REDIS_HOST=<redis-host>
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=<redis-password-if-required>
ENABLE_CACHING=True
